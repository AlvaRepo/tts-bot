# Kick bot configuration for TTS_Free
# Copy this file to .env (or merge these vars into your existing .env)

# Bot identity
KICK_BOT_USERNAME=SrtaBot
KICK_BOT_CHANNEL=srtavodka
KICK_BOT_PREFIX=!

# Auth (fill with your current session values)
KICK_BOT_BEARER=
KICK_BOT_XSRF=
KICK_BOT_COOKIES=

# Optional behavior toggles
KICK_BOT_ENABLED=false
KICK_BOT_ALLOW_TTS_FROM_CHAT=false
KICK_BOT_ALLOW_COMMANDS_FROM_MODS=true
