# Configuración del Servidor
PORT=49152
WS_PORT=49153
MAX_MESSAGE_LENGTH=300
MAX_RETRIES=3
MESSAGES_DB_PATH=./messages.db
AUDIO_CACHE_DIR=./audio_cache

# Configuración TTS
TTS_VOICE=es-AR-TomasNeural

# Perfil de Audio
AUDIO_PROFILE=auto

# Supabase (NUEVO - Requerido para migración)
SUPABASE_URL=https://tu-proyecto.supabase.co
SUPABASE_ANON_KEY=tu_anon_key_aqui
SUPABASE_SERVICE_ROLE_KEY=tu_service_role_key_aqui

# Webhooks (opcional)
DONORDRIVE_WEBHOOK_SECRET=tu_secret_aqui

# Kick Bot (opcional)
KICK_BOT_ENABLED=false
KICK_BOT_CHANNEL=
KICK_BOT_PREFIX=!

# OAuth for Bot Chat (required for sending messages)
KICK_OAUTH_CLIENT_ID=
KICK_OAUTH_CLIENT_SECRET=
KICK_OAUTH_REDIRECT_URI=https://tu-app.onrender.com/oauth/callback

# Render (for production)
RENDER_EXTERNAL_URL=tu-app.onrender.com
